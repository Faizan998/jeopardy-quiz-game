generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String?
  role             Role
  image            String?
  resetToken       String?
  resetTokenExpiry DateTime?
  totalAmount      Int       @default(0)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt
  Answer           Answer[]
  blogs            Blog[]
}

